---
// src/layouts/BaseLayout.astro
// The shell every page inherits. Prop contract is fixed — later tasks
// (Home, Work, About, Contact) depend on this exact signature. The two
// `alternateLocales`/`langAltHref` props added in Task 13 are additive-only
// (optional, undefined by default): every existing call site is unaffected
// and renders byte-identical output. They exist for the first genuinely
// locale-asymmetric page (/en/resume/, no zh counterpart by design) so it
// doesn't advertise hreflang alternates or a language-switcher link that
// point at a URL nothing builds.
import Seo from '../components/Seo.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  lang: 'zh' | 'en';
  title: string;
  description: string;
  path: string;
  jsonLd?: Record<string, unknown>[];
  alternateLocales?: ('zh' | 'en')[];
  langAltHref?: string;
}

const { lang, title, description, path, jsonLd, alternateLocales, langAltHref } = Astro.props;

const skipLabel = lang === 'zh' ? '跳到主要内容' : 'Skip to content';
---

<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <Seo lang={lang} title={title} description={description} path={path} jsonLd={jsonLd} alternateLocales={alternateLocales} />
  </head>
  <body>
    <a class="skip-link" href="#main">{skipLabel}</a>
    <Header lang={lang} altHref={langAltHref} />
    <main id="main" class="site-main">
      <slot />
    </main>
    <Footer lang={lang} />
  </body>
</html>

<style>
  .site-main {
    flex: 1 0 auto;
    width: 100%;
  }
</style>
