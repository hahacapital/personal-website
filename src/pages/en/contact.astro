---
// src/pages/en/contact.astro
// The English Contact page: intro line → direct contact ledger (email/WeChat)
// → résumé (links to the /en/resume/ HTML page, not a PDF — see
// contact-content.ts / ContactBody.astro for the reasoning). All markup/styles
// live in ContactBody; this file just wires BaseLayout with the real
// title/description for this route.
import BaseLayout from '../../layouts/BaseLayout.astro';
import ContactBody from '../../components/ContactBody.astro';
import { buildBreadcrumbListJsonLd } from '../../lib/geo';
import { siteConfig } from '../../data/site';
import { useTranslations } from '../../i18n/utils';

const lang = 'en' as const;
const t = useTranslations(lang);

const title = 'Contact Yixiang Zhang · Independent Forward Deployed Engineer';
const description =
  'Contact Yixiang Zhang about an AI Agent project: email and WeChat, plus an English résumé.';

// Sitewide BreadcrumbList (final-review Finding 1 — the design spec called
// for this, but it was dropped when the spec was translated into concrete
// implementation tasks). Home > Contact; see src/lib/geo.ts.
const jsonLd = [
  buildBreadcrumbListJsonLd([
    { name: t('nav.home'), url: `${siteConfig.siteUrl}/${lang}/` },
    { name: t('nav.contact'), url: `${siteConfig.siteUrl}/${lang}/contact/` },
  ]),
];
---

<BaseLayout lang={lang} title={title} description={description} path="contact" jsonLd={jsonLd}>
  <ContactBody lang={lang} />
</BaseLayout>
