---
// src/pages/zh/about.astro
// The Simplified-Chinese About page: career narrative → Timeline (Task 10,
// reused as-is with the existing 3-entry data) → working philosophy →
// education. All markup/styles live in AboutBody; this file just wires
// BaseLayout with the real title/description for this route.
import BaseLayout from '../../layouts/BaseLayout.astro';
import AboutBody from '../../components/AboutBody.astro';
import { buildBreadcrumbListJsonLd } from '../../lib/geo';
import { siteConfig } from '../../data/site';
import { useTranslations } from '../../i18n/utils';

const lang = 'zh' as const;
const t = useTranslations(lang);

const title = '关于张翼翔 · 独立 Forward Deployed Engineer';
const description =
  '张翼翔的职业历程：蚂蚁金服区块链技术专家、新核云技术总监，现为独立 Forward Deployed Engineer。工作理念、教育背景与完整履历。';

// Sitewide BreadcrumbList (final-review Finding 1 — the design spec called
// for this, but it was dropped when the spec was translated into concrete
// implementation tasks). 首页 > 关于; see src/lib/geo.ts.
const jsonLd = [
  buildBreadcrumbListJsonLd([
    { name: t('nav.home'), url: `${siteConfig.siteUrl}/${lang}/` },
    { name: t('nav.about'), url: `${siteConfig.siteUrl}/${lang}/about/` },
  ]),
];
---

<BaseLayout lang={lang} title={title} description={description} path="about" jsonLd={jsonLd}>
  <AboutBody lang={lang} />
</BaseLayout>
