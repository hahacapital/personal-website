---
// src/pages/zh/work/[slug].astro
// Simplified-Chinese case study route. One static page per entry in the workZh
// collection (the five shipped case studies); the entry's frontmatter fields
// flow straight into the shared CaseStudyLayout, and the Markdown body renders
// through <Content /> into the layout's prose slot.
import { getCollection, render } from 'astro:content';
import CaseStudyLayout from '../../../layouts/CaseStudyLayout.astro';

export async function getStaticPaths() {
  const entries = await getCollection('workZh');
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---
<CaseStudyLayout
  lang="zh"
  title={entry.data.title}
  summary={entry.data.summary}
  path={`work/${entry.id}`}
  metrics={entry.data.metrics}
  faqs={entry.data.faqs}
  updatedDate={entry.data.updatedDate}
>
  <Content />
</CaseStudyLayout>
