---
// src/components/IdentityPillars.astro
// The three-part answer to "who is this". These are NOT identical icon-cards:
// they're a deliberately-typed set of three, so a mono index (01/02/03) is
// earned here — the three pillars ARE the sequence, not per-section scaffolding.
// Each pillar is a title over a hairline-ruled list of proof points; the proof
// points carry specific systems and numbers ("evidence over adjectives").
import type { Locale } from '../i18n/utils';
import { homeContent } from '../data/home-content';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
const { pillars } = homeContent[lang];

const heading = {
  zh: '三个身份，同一个人',
  en: 'Three roles, one person',
}[lang];
---

<section class="pillars" aria-labelledby="pillars-heading">
  <div class="container">
    <h2 class="pillars__heading" id="pillars-heading">{heading}</h2>

    <ol class="pillars__list">
      {pillars.map((pillar, i) => (
        <li class="pillar">
          <span class="pillar__index" aria-hidden="true">
            {String(i + 1).padStart(2, '0')}
          </span>
          <div class="pillar__body">
            <h3 class="pillar__title">{pillar.title}</h3>
            <ul class="pillar__proof">
              {pillar.proofPoints.map((point) => (
                <li class="pillar__proof-item">
                  <span class="pillar__tick" aria-hidden="true"></span>
                  <span class="pillar__proof-text">{point}</span>
                </li>
              ))}
            </ul>
          </div>
        </li>
      ))}
    </ol>
  </div>
</section>

<style>
  .pillars {
    padding-block: var(--space-2xl);
    border-top: 1px solid var(--color-hairline);
  }

  .pillars__heading {
    max-width: 24ch;
    margin-bottom: var(--space-xl);
    font-size: var(--text-h2);
  }

  .pillars__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0;
  }

  /* Each pillar is a ledger row: a mono index in a narrow rail, the content in
     the wide column. Rows are separated by hairlines, not boxed as cards. */
  .pillar {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-md);
    padding-block: var(--space-xl);
    border-top: 1px solid var(--color-hairline);
  }
  .pillar:first-child { border-top: 0; padding-top: 0; }

  @media (min-width: 40rem) {
    .pillar {
      grid-template-columns: 3.5rem minmax(0, 1fr);
      gap: var(--space-lg);
    }
  }

  .pillar__index {
    font-family: var(--font-mono);
    font-size: var(--text-body);
    font-weight: 500;
    font-variant-numeric: tabular-nums;
    letter-spacing: 0.02em;
    line-height: 1.3;
    color: var(--color-primary);
  }

  .pillar__title {
    font-size: var(--text-h3);
    line-height: 1.2;
    text-wrap: balance;
  }

  .pillar__proof {
    list-style: none;
    margin: var(--space-md) 0 0;
    padding: 0;
    display: grid;
    gap: var(--space-sm);
    max-width: var(--measure);
  }

  .pillar__proof-item {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    align-items: start;
    gap: 0.75rem;
    color: var(--color-muted);
    font-size: var(--text-body);
    line-height: 1.55;
  }

  /* A short coral rule as the marker — a shape cue, never color alone. */
  .pillar__tick {
    margin-top: 0.62em;
    width: 0.875rem;
    height: 2px;
    border-radius: 2px;
    background: var(--color-primary);
    flex: none;
  }
  .pillar__proof-text { text-wrap: pretty; }
</style>
