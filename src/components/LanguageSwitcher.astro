---
// src/components/LanguageSwitcher.astro
// A two-state toggle (中 / EN) rendered as a segmented control. The active
// language is marked with aria-current AND a filled segment (not color
// alone), so the state is legible without relying on hue. The inactive
// segment is a real link to the same page in the other language, built
// from the current pathname via getLocalizedPath.
import type { Locale } from '../i18n/utils';
import { getLocalizedPath, locales } from '../i18n/utils';

interface Props {
  lang: Locale;
  // Override the mechanically-derived cross-locale link. Every page except
  // one has a real counterpart at getLocalizedPath(pathname, otherLocale),
  // so this is optional and undefined by default. The one exception is
  // /en/resume/ (no zh counterpart by design — zh links straight to a PDF
  // instead), which passes the actual zh destination (/zh/contact/) so the
  // "中" segment never points at a URL nothing builds.
  altHref?: string;
}

const { lang, altHref } = Astro.props;

// Short, symmetric labels — one glyph each keeps the control compact and
// balanced across zh/en. Chinese uses the character 中; English uses EN.
const labels: Record<Locale, string> = { zh: '中', en: 'EN' };

const pathname = Astro.url.pathname;

const segments = locales.map((code) => {
  const isCurrent = code === lang;
  const usesOverride = !isCurrent && !!altHref;
  return {
    code,
    label: labels[code],
    href: usesOverride ? (altHref as string) : getLocalizedPath(pathname, code),
    current: isCurrent,
    // `rel="alternate" hreflang="…"` asserts "this is the same content in
    // another language" — true for the mechanically-derived link, but NOT
    // true when altHref points at a different page (e.g. /zh/contact/ isn't
    // a translation of /en/resume/), so that annotation is dropped there.
    // `lang` stays either way: the destination's declared language is
    // accurate regardless of which page it is.
    isAlternate: !usesOverride,
  };
});
---

<nav class="lang" aria-label="Language">
  <ul class="lang__list">
    {segments.map((seg) => (
      <li>
        {seg.current ? (
          <span class="lang__seg lang__seg--current" aria-current="true">
            {seg.label}
          </span>
        ) : (
          <a
            class="lang__seg"
            href={seg.href}
            hreflang={seg.isAlternate ? seg.code : undefined}
            lang={seg.code}
            rel={seg.isAlternate ? 'alternate' : undefined}
          >
            {seg.label}
          </a>
        )}
      </li>
    ))}
  </ul>
</nav>

<style>
  .lang {
    display: inline-flex;
  }

  .lang__list {
    display: inline-flex;
    align-items: stretch;
    gap: 0;
    margin: 0;
    padding: 2px;
    list-style: none;
    border: 1px solid var(--color-hairline);
    border-radius: var(--radius-pill);
    background: var(--color-surface);
  }

  .lang__seg {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 2.5rem;
    min-height: 1.75rem;
    padding: 0 0.5rem;
    font-family: var(--font-mono);
    font-size: var(--text-caption);
    font-weight: 500;
    letter-spacing: 0.02em;
    line-height: 1;
    border-radius: var(--radius-pill);
    text-decoration: none;
    color: var(--color-muted);
    transition:
      color var(--dur-fast) var(--ease-out-quart),
      background-color var(--dur-fast) var(--ease-out-quart);
  }

  /* Expand the tap/hit area to >=44px without inflating the visual pill
     (WCAG 2.5.5 target size). The pseudo-element overlays the gap between
     the compact segment and a comfortable touch target. */
  .lang__seg::after {
    content: '';
    position: absolute;
    inset: -0.5rem -0.125rem;
  }

  a.lang__seg:hover {
    color: var(--color-ink);
    background: color-mix(in oklch, var(--color-ink) 6%, transparent);
  }

  /* Active state: filled + inked. The fill (not just the color) carries the
     "you are here" affordance so it survives grayscale / color-blind viewing. */
  .lang__seg--current {
    color: var(--color-bg);
    background: var(--color-ink);
    cursor: default;
  }

  .lang__seg:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
  }
</style>
