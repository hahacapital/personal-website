# build output
dist/
# generated types
.astro/

# dependencies
node_modules/

# logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*


# environment variables
.env
.env.production

# macOS-specific files
.DS_Store

# jetbrains setting folder
.idea/

# impeccable design-hook local cache (per-session edit state; not shipped).
# The critique/ snapshots under .impeccable/ stay tracked as design-review history.
.impeccable/hook.cache.json

# taste-skill (Task 20 secondary, non-authoritative design cross-check tool).
# Installed locally as a second opinion against impeccable's DESIGN.md (the
# system of record); not part of the shipped site, so kept out of the repo.
# The tracked impeccable skill under .claude/skills/impeccable/ is unaffected.
.agents/
.claude/skills/brandkit
.claude/skills/design-taste-frontend
.claude/skills/design-taste-frontend-v1
.claude/skills/full-output-enforcement
.claude/skills/gpt-taste
.claude/skills/high-end-visual-design
.claude/skills/image-to-code
.claude/skills/imagegen-frontend-mobile
.claude/skills/imagegen-frontend-web
.claude/skills/industrial-brutalist-ui
.claude/skills/minimalist-ui
.claude/skills/redesign-existing-projects
.claude/skills/stitch-design-taste
skills-lock.json

# Terraform (infra/aws-static-site) — local provider cache/state/vars, never
# shipped or committed. `.terraform.lock.hcl` is NOT ignored — it pins exact
# provider versions/hashes and should be committed, like a lockfile. State
# should live in a remote backend before this is used by more than one
# operator; see infra/aws-static-site/README.md.
**/.terraform/
*.tfstate
*.tfstate.*
*.tfvars
!*.tfvars.example
crash.log
crash.*.log
